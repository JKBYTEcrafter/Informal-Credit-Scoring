APP_NAME=Alternative Credit Intelligence Platform
ENVIRONMENT=development
API_PREFIX=/api
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/alternative_credit
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTO_CREATE_TABLES=True
ML_MODEL_DIR=app/ml/artifacts
ML_MODEL_VERSION=sprint2-credit-score-v1
ML_SYNTHETIC_TRAINING_ROWS=1200
ML_RANDOM_SEED=42
