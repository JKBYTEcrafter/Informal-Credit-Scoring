# ============================================================
# Alternative Credit Intelligence Platform — Production .env
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's in .gitignore).

# ---- Application ----
APP_NAME="Alternative Credit Intelligence Platform"
ENVIRONMENT=production
API_PREFIX=/api

# ---- Database (choose ONE) ----
# Option A: Neon PostgreSQL (LIFETIME FREE — recommended)
# Get your URL from: https://neon.tech → New Project → Connection String
DATABASE_URL=postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require

# Option B: Supabase PostgreSQL (500MB free, lifetime)
# DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Option C: Railway PostgreSQL (trial credits)
# DATABASE_URL=postgresql://postgres:password@roundhouse.proxy.rlwy.net:PORT/railway

# Option D: SQLite (local dev only, NOT for production)
# DATABASE_URL=sqlite:///./app.db

# ---- Security ----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters-change-this

# ---- CORS (your deployed frontend URL) ----
# Vercel: https://your-app.vercel.app
# Custom domain: https://yourdomain.com
BACKEND_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ---- ML Configuration ----
AUTO_CREATE_TABLES=True
ML_MODEL_DIR=app/ml/artifacts
ML_MODEL_VERSION=sprint2-credit-score-v1
ML_SYNTHETIC_TRAINING_ROWS=1200
ML_RANDOM_SEED=42
